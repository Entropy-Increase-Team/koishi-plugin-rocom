<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>远行商人</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fraunces:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
@font-face {
    font-family: "fzlant";
    src: url("{{_res_path}}ttf/fzlant.D5FI9Et0.ttf");
}

@font-face {
    font-family: "dundun";
    src: url("{{_res_path}}ttf/dundun.xHd_Ee5-.woff2");
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    /* Warm earthy palette */
    --bg-cream: #F7F4EF;
    --surface-warm: #FBF9F5;
    --surface-white: #FFFFFF;
    --border-hairline: #E7E1D7;
    --ink: #1F2421;
    --text-muted: #5C635D;
    --terracotta: #C4612F;
    --terracotta-hover: #A94E22;
    --terracotta-tint: #F2E3D6;
    --charcoal: #1F2421;

    /* Typography */
    --font-sans: 'Inter', 'fzlant', 'Microsoft YaHei', 'PingFang SC', sans-serif;
    --font-serif: 'Fraunces', 'dundun', 'fzlant', Georgia, serif;
}

html,
body {
    width: 100%;
    height: auto;
    font-family: var(--font-sans);
    color: var(--ink);
    background: var(--bg-cream);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.merchant-page {
    position: relative;
    width: min(1200px, 100%);
    margin: 0 auto;
    background: var(--bg-cream);
    padding: 32px;
}

.hero {
    position: relative;
    padding: 48px 40px;
    border-radius: 24px;
    background: var(--surface-white);
    border: 1px solid var(--border-hairline);
    box-shadow: 0 2px 8px rgba(31, 36, 33, 0.04);
    margin-bottom: 24px;
}

.hero-eyebrow {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 999px;
    background: var(--terracotta-tint);
    color: var(--terracotta);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
}

.hero-title {
    font-family: var(--font-serif);
    font-size: 56px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--ink);
}

.hero-title em {
    font-style: italic;
    color: var(--terracotta);
}

.hero-subtitle {
    font-size: 18px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 600px;
}

.hero-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border-hairline);
}

.meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    background: var(--surface-warm);
    border: 1px solid var(--border-hairline);
    font-size: 15px;
    font-weight: 500;
}

.meta-chip-label {
    color: var(--text-muted);
    font-weight: 400;
}

.meta-chip-value {
    color: var(--ink);
    font-weight: 600;
}

.meta-chip.accent .meta-chip-value {
    color: var(--terracotta);
}

.products-section {
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.category-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.category-header {
    display: flex;
    align-items: center;
    gap: 12px;
}

.category-title {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
}

.category-badge {
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
}

.category-badge.normal {
    background: rgba(46, 125, 50, 0.12);
    color: #2E7D32;
}

.category-badge.round {
    background: rgba(25, 118, 210, 0.12);
    color: #1976D2;
}

.category-badge.weekend {
    background: rgba(211, 47, 47, 0.12);
    color: #D32F2F;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
}

.product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 24px;
    border-radius: 16px;
    background: var(--surface-white);
    border: 1px solid var(--border-hairline);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(31, 36, 33, 0.08);
}

.product-image-wrap {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 12px;
    background: var(--surface-warm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    overflow: hidden;
}

.product-image {
    width: 80%;
    height: 80%;
    object-fit: contain;
}

.product-name {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 8px;
}

.product-time {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--terracotta-tint);
    color: var(--terracotta);
    font-size: 13px;
    font-weight: 500;
    margin-top: 8px;
}

.product-time::before {
    content: '⏱';
    font-size: 14px;
}

.empty-state {
    text-align: center;
    padding: 64px 32px;
    border-radius: 16px;
    border: 1px dashed var(--border-hairline);
    background: var(--surface-warm);
}

.empty-state-icon {
    font-size: 48px;
    margin-bottom: 16px;
    opacity: 0.4;
}

.empty-state-text {
    font-size: 18px;
    font-weight: 400;
    color: var(--text-muted);
}

@media (max-width: 768px) {
    .merchant-page {
        padding: 16px;
    }

    .hero {
        padding: 32px 24px;
    }

    .hero-title {
        font-size: 36px;
    }

    .hero-meta {
        flex-wrap: wrap;
    }

    .products-grid {
        grid-template-columns: 1fr;
    }
}
    </style>
</head>
<body>
    <div class="merchant-page">
        <header class="hero">
            <span class="hero-eyebrow">每日刷新</span>
            <h1 class="hero-title">远行<em>商人</em></h1>
            <p class="hero-subtitle">{{subtitle}}</p>
            <div class="hero-meta">
                <div class="meta-chip accent">
                    <span class="meta-chip-label">当前商品</span>
                    <span class="meta-chip-value">{{product_count}} 件</span>
                </div>
                <div class="meta-chip">
                    <span class="meta-chip-label">轮次</span>
                    <span class="meta-chip-value">{{round_info.current || '未开放'}} / {{round_info.total}}</span>
                </div>
                <div class="meta-chip">
                    <span class="meta-chip-label">剩余</span>
                    <span class="meta-chip-value">{{round_info.countdown}}</span>
                </div>
            </div>
        </header>

        <main class="products-section">
            {{if categories && categories.length > 0}}
                {{each categories cat}}
                <section class="category-group">
                    <div class="category-header">
                        <h2 class="category-title">{{cat.label}}</h2>
                        <span class="category-badge {{cat.key}}">{{cat.products.length}} 件</span>
                    </div>
                    <div class="products-grid">
                        {{each cat.products product}}
                        <article class="product-card">
                            <div class="product-image-wrap">
                                <img class="product-image" src="{{product.image}}" alt="{{product.name}}" loading="lazy">
                            </div>
                            <h3 class="product-name">{{product.name}}</h3>
                            {{if product.time_label}}
                            <div class="product-time">{{product.time_label}}</div>
                            {{/if}}
                        </article>
                        {{/each}}
                    </div>
                </section>
                {{/each}}
            {{else}}
                <div class="empty-state">
                    <div class="empty-state-icon">📦</div>
                    <p class="empty-state-text">本轮暂无商品，稍后再来看看</p>
                </div>
            {{/if}}
        </main>
    </div>
</body>
</html>
